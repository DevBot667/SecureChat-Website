---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title="SecureChat — Changelog">

  <div id="scroll-progress"></div>

  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 glass-strong">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href={base} class="flex items-center gap-3 group">
        <svg class="w-8 h-8 transition-transform group-hover:scale-110" viewBox="0 0 64 64" fill="none"><defs><linearGradient id="nav-g" x1="0" y1="0" x2="64" y2="64" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#9C4DCC"/><stop offset="100%" stop-color="#7B2D8E"/></linearGradient></defs><rect width="64" height="64" rx="14" fill="url(#nav-g)"/><path d="M22 30v-6a10 10 0 0 1 20 0v6h-4v-6a6 6 0 0 0-12 0v6z" fill="#fff"/><rect x="18" y="30" width="28" height="22" rx="4" fill="#fff"/><circle cx="32" cy="39" r="3.5" fill="#7B2D8E"/><path d="M31 42h2v5h-2z" fill="#7B2D8E"/></svg>
        <span class="text-xl font-bold font-['Space_Grotesk']">Secure<span class="text-phantom-light">Chat</span></span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm text-text-secondary">
        <a href={base} class="hover:text-phantom-light transition-colors">Home</a>
        <a href={`${base}how-it-works`} class="hover:text-phantom-light transition-colors">How it Works</a>
        <a href={`${base}changelog`} class="text-phantom-light font-semibold">Changelog</a>
      </div>
      <div class="flex items-center gap-4">
        <button id="lang-toggle" class="text-sm px-3 py-1.5 rounded-lg border border-phantom/30 hover:border-phantom-light hover:text-phantom-light transition-all cursor-pointer"><span data-lang="fr">EN</span><span data-lang="en">FR</span></button>
        <a href="https://github.com/DevBot667/SecureChat" target="_blank" rel="noopener noreferrer" class="hidden sm:inline-flex items-center gap-2 px-4 py-2 bg-phantom hover:bg-phantom-light text-white text-sm font-medium rounded-xl transition-all hover:scale-105 glow-phantom">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer" aria-label="Menu">
          <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar1"></span>
          <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar2"></span>
          <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar3"></span>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden hidden glass-strong border-t border-white/5">
      <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-3 text-sm">
        <a href={base} class="py-2 text-text-secondary hover:text-phantom-light transition-colors">Home</a>
        <a href={`${base}how-it-works`} class="py-2 text-text-secondary hover:text-phantom-light transition-colors">How it Works</a>
        <a href={`${base}changelog`} class="py-2 text-phantom-light font-semibold">Changelog</a>
        <a href="https://github.com/DevBot667/SecureChat" target="_blank" rel="noopener noreferrer" class="py-2 text-phantom-light hover:text-phantom transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
      </div>
    </div>
  </nav>

  <!-- Header -->
  <section class="pt-32 pb-16 animated-gradient">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-5xl md:text-6xl font-black font-['Space_Grotesk'] mb-6" data-lang="fr">Journal des <span class="gradient-text">modifications</span></h1>
      <h1 class="text-5xl md:text-6xl font-black font-['Space_Grotesk'] mb-6" data-lang="en"><span class="gradient-text">Changelog</span></h1>
      <p class="text-xl text-text-secondary" data-lang="fr">Toutes les versions de SecureChat, au fur et à mesure.</p>
      <p class="text-xl text-text-secondary" data-lang="en">Every SecureChat release, as they happen.</p>
    </div>
  </section>

  <!-- Changelog Content -->
  <section class="py-24">
    <div class="max-w-3xl mx-auto px-6">
      <div id="changelog-loading" class="space-y-8 py-4">
        <!-- Skeleton title -->
        <div class="skeleton h-10 w-64 mb-4"></div>
        <!-- Skeleton version block -->
        <div class="space-y-3">
          <div class="skeleton h-7 w-48"></div>
          <div class="skeleton h-px w-full opacity-50"></div>
          <div class="skeleton h-5 w-32 mt-3"></div>
          <div class="space-y-2 mt-2">
            <div class="skeleton h-4 w-full"></div>
            <div class="skeleton h-4 w-5/6"></div>
            <div class="skeleton h-4 w-4/5"></div>
            <div class="skeleton h-4 w-full"></div>
            <div class="skeleton h-4 w-3/4"></div>
          </div>
        </div>
        <!-- Skeleton version block 2 -->
        <div class="space-y-3">
          <div class="skeleton h-7 w-40"></div>
          <div class="skeleton h-px w-full opacity-50"></div>
          <div class="skeleton h-5 w-28 mt-3"></div>
          <div class="space-y-2 mt-2">
            <div class="skeleton h-4 w-full"></div>
            <div class="skeleton h-4 w-5/6"></div>
            <div class="skeleton h-4 w-3/5"></div>
            <div class="skeleton h-4 w-full"></div>
          </div>
        </div>
        <!-- Skeleton version block 3 -->
        <div class="space-y-3">
          <div class="skeleton h-7 w-44"></div>
          <div class="skeleton h-px w-full opacity-50"></div>
          <div class="skeleton h-5 w-36 mt-3"></div>
          <div class="space-y-2 mt-2">
            <div class="skeleton h-4 w-full"></div>
            <div class="skeleton h-4 w-4/6"></div>
            <div class="skeleton h-4 w-5/6"></div>
          </div>
        </div>
      </div>
      <div id="changelog-error" class="hidden text-center py-12">
        <div class="glass rounded-2xl p-8 inline-block">
          <div class="text-4xl mb-4">⚠️</div>
          <p class="text-text-secondary mb-4" data-lang="fr">Impossible de charger le changelog. Vérifiez votre connexion.</p>
          <p class="text-text-secondary mb-4" data-lang="en">Could not load changelog. Check your connection.</p>
          <button id="retry-btn" class="px-6 py-2 bg-phantom hover:bg-phantom-light text-white text-sm font-medium rounded-xl transition-all cursor-pointer"><span data-lang="fr">Réessayer</span><span data-lang="en">Retry</span></button>
        </div>
      </div>
      <div id="changelog-fr" class="changelog-content hidden"></div>
      <div id="changelog-en" class="changelog-content hidden"></div>
    </div>
  </section>

  <!-- Rocket Back to Top -->
  <button id="rocket-top" aria-label="Back to top" class="fixed bottom-8 right-8 z-50 w-16 h-16 rounded-full bg-surface/80 backdrop-blur-md border border-phantom/40 flex items-center justify-center cursor-pointer opacity-0 translate-y-8 pointer-events-none transition-all duration-500 hover:scale-110 group">
    <div class="rocket-glow absolute -inset-2 rounded-full pointer-events-none"></div>
    <svg class="w-9 h-9 transition-transform duration-300 group-hover:-translate-y-1 relative z-10" viewBox="0 0 64 64" fill="none">
      <defs>
        <linearGradient id="rtBody" x1="32" y1="4" x2="32" y2="48" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#D68FFF"/>
          <stop offset="40%" stop-color="#9C4DCC"/>
          <stop offset="100%" stop-color="#6B2FA0"/>
        </linearGradient>
        <radialGradient id="rtPort" cx="50%" cy="40%" r="55%">
          <stop offset="0%" stop-color="#E0B0FF" stop-opacity="0.9"/>
          <stop offset="70%" stop-color="#9C4DCC" stop-opacity="0.4"/>
          <stop offset="100%" stop-color="#6B2FA0" stop-opacity="0.1"/>
        </radialGradient>
      </defs>
      <path d="M32 4 C32 4 18 18 18 40 L24 47 L40 47 L46 40 C46 18 32 4 32 4Z" fill="url(#rtBody)"/>
      <path d="M32 4 C32 4 26 14 25 26 L32 6 L39 26 C38 14 32 4 32 4Z" fill="#D68FFF" opacity="0.25"/>
      <circle cx="32" cy="26" r="7" fill="none" stroke="#B44FE0" stroke-width="0.8" opacity="0.4"/>
      <circle cx="32" cy="26" r="5.5" fill="#0A0A10" stroke="#B44FE0" stroke-width="1.5"/>
      <circle cx="32" cy="26" r="4" fill="url(#rtPort)"/>
      <circle cx="30" cy="24" r="1.5" fill="white" opacity="0.35"/>
      <circle cx="33.5" cy="28" r="0.7" fill="white" opacity="0.15"/>
      <path d="M18 36 L9 52 L18 44Z" fill="#7B2D8E"/>
      <path d="M46 36 L55 52 L46 44Z" fill="#7B2D8E"/>
      <path d="M18 36 L11 49 L18 42Z" fill="#9C4DCC" opacity="0.3"/>
      <path d="M46 36 L53 49 L46 42Z" fill="#9C4DCC" opacity="0.3"/>
      <ellipse cx="32" cy="45" rx="8" ry="2.5" fill="#5A1F7A" stroke="#9C4DCC" stroke-width="0.5" opacity="0.7"/>
      <line x1="24" y1="38" x2="40" y2="38" stroke="#B44FE0" stroke-width="0.5" opacity="0.25"/>
      <line x1="22" y1="42" x2="42" y2="42" stroke="#B44FE0" stroke-width="0.5" opacity="0.15"/>
    </svg>
    <div class="rocket-flames absolute -bottom-4 left-1/2 -translate-x-1/2 flex gap-0.5 opacity-0 group-hover:opacity-100 transition-opacity z-10">
      <div class="w-1 h-3 bg-gradient-to-b from-orange-300 to-orange-600 rounded-full animate-flame1 opacity-90"></div>
      <div class="w-1.5 h-5 bg-gradient-to-b from-yellow-200 to-orange-500 rounded-full animate-flame2"></div>
      <div class="w-2 h-6 bg-gradient-to-b from-white to-yellow-400 rounded-full animate-flame2" style="animation-delay:-0.1s;"></div>
      <div class="w-1.5 h-5 bg-gradient-to-b from-yellow-200 to-orange-500 rounded-full animate-flame2" style="animation-delay:-0.15s;"></div>
      <div class="w-1 h-3 bg-gradient-to-b from-orange-300 to-orange-600 rounded-full animate-flame3 opacity-90"></div>
    </div>
    <div class="absolute -bottom-10 left-1/2 -translate-x-1/2 w-4 h-10 bg-gradient-to-b from-orange-400/20 via-phantom/10 to-transparent rounded-full blur-md opacity-0 group-hover:opacity-100 transition-opacity" id="rocket-top-exhaust"></div>
  </button>
  <style>
    @keyframes flame1 { 0%,100% { height: 10px; opacity: 0.8; } 50% { height: 18px; opacity: 1; } }
    @keyframes flame2 { 0%,100% { height: 16px; opacity: 0.9; } 50% { height: 24px; opacity: 1; } }
    @keyframes flame3 { 0%,100% { height: 8px; opacity: 0.7; } 50% { height: 16px; opacity: 1; } }
    .animate-flame1 { animation: flame1 0.3s ease-in-out infinite; }
    .animate-flame2 { animation: flame2 0.25s ease-in-out infinite; }
    .animate-flame3 { animation: flame3 0.35s ease-in-out infinite; }
    #rocket-top { filter: drop-shadow(0 0 10px rgba(156,77,204,0.3)); }
    @keyframes rocketGlow {
      0%, 100% { filter: drop-shadow(0 0 10px rgba(156,77,204,0.3)); }
      50% { filter: drop-shadow(0 0 22px rgba(156,77,204,0.6)); }
    }
    #rocket-top.visible { opacity: 1; transform: translateY(0); pointer-events: auto; animation: rocketGlow 3s ease-in-out infinite; }
    .rocket-glow {
      background: radial-gradient(circle, rgba(156,77,204,0.15) 0%, transparent 70%);
      animation: rocketGlowRing 2s ease-in-out infinite;
    }
    @keyframes rocketGlowRing {
      0%, 100% { transform: scale(1); opacity: 0.4; }
      50% { transform: scale(1.3); opacity: 0.7; }
    }
    #rocket-top.launching {
      animation: rocketLaunch 0.8s ease-in forwards !important;
    }
    @keyframes rocketLaunch {
      0% { transform: translateY(0) scale(1); filter: drop-shadow(0 0 10px rgba(156,77,204,0.4)); }
      20% { transform: translateY(8px) scale(1.15); filter: drop-shadow(0 0 30px rgba(156,77,204,0.8)); }
      100% { transform: translateY(-120vh) scale(0.5); opacity: 0; filter: drop-shadow(0 0 40px rgba(156,77,204,1)); }
    }
    #rocket-top.launching .rocket-flames { opacity: 1 !important; }
    #rocket-top.launching .rocket-flames div { height: 1.5rem !important; }
    #rocket-top.launching #rocket-top-exhaust { opacity: 1 !important; height: 4rem; }
    #rocket-top.launching .rocket-glow { transform: scale(2); opacity: 1; }
  </style>

  <!-- Footer -->
  <footer class="py-12 border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <span class="text-sm text-text-secondary">SecureChat — <span data-lang="fr">par</span><span data-lang="en">by</span> <a href="https://github.com/DevBot667" target="_blank" rel="noopener noreferrer" class="text-phantom-light hover:underline">DevBot667</a></span>
      <div class="flex items-center gap-6 text-sm text-text-muted">
        <a href={base} class="hover:text-phantom-light transition-colors">Home</a>
        <a href={`${base}how-it-works`} class="hover:text-phantom-light transition-colors">How it Works</a>
        <span>GPLv3</span>
      </div>
    </div>
  </footer>

  <script>
    import { marked } from 'marked';

    // Mobile Menu Toggle
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    mobileMenuBtn?.addEventListener('click', () => {
      mobileMenuBtn.closest('nav')?.classList.toggle('menu-open');
      mobileMenu?.classList.toggle('hidden');
      mobileMenu?.classList.toggle('open');
    });

    const BASE = 'https://raw.githubusercontent.com/DevBot667/SecureChat/main/docs';
    const elFr = document.getElementById('changelog-fr')!;
    const elEn = document.getElementById('changelog-en')!;
    const elLoading = document.getElementById('changelog-loading')!;
    const elError = document.getElementById('changelog-error')!;

    let currentLang = 'fr';
    let loaded = false;

    // Language
    const langToggle = document.getElementById('lang-toggle');
    langToggle?.addEventListener('click', () => {
      currentLang = currentLang === 'fr' ? 'en' : 'fr';
      document.documentElement.classList.remove('lang-fr','lang-en');
      document.documentElement.classList.add(`lang-${currentLang}`);
      document.documentElement.lang = currentLang;
      showCurrentLang();
    });

    function showCurrentLang() {
      if (!loaded) return;
      elFr.classList.toggle('hidden', currentLang !== 'fr');
      elEn.classList.toggle('hidden', currentLang !== 'en');
    }

    async function fetchChangelogs() {
      elLoading.classList.remove('hidden');
      elError.classList.add('hidden');
      elFr.classList.add('hidden');
      elEn.classList.add('hidden');
      try {
        const [resFr, resEn] = await Promise.all([
          fetch(`${BASE}/fr/CHANGELOG.md`),
          fetch(`${BASE}/en/CHANGELOG.md`)
        ]);
        if (!resFr.ok && !resEn.ok) throw new Error('Both failed');
        const mdFr = resFr.ok ? await resFr.text() : '# Changelog\n\n_Pas encore disponible._';
        const mdEn = resEn.ok ? await resEn.text() : '# Changelog\n\n_Not available yet._';
        elFr.innerHTML = await marked.parse(mdFr);
        elEn.innerHTML = await marked.parse(mdEn);
        loaded = true;
        elLoading.classList.add('hidden');
        showCurrentLang();
      } catch (e) {
        elLoading.classList.add('hidden');
        elError.classList.remove('hidden');
      }
    }

    document.getElementById('retry-btn')?.addEventListener('click', fetchChangelogs);

    // Scroll progress
    const sp = document.getElementById('scroll-progress');
    window.addEventListener('scroll', () => { if (!sp) return; const h = document.documentElement.scrollHeight - window.innerHeight; sp.style.width = h > 0 ? `${(window.scrollY/h*100)}%` : '0%'; });

    fetchChangelogs();

    // ---- Rocket Back to Top ----
    const rocketBtn = document.getElementById('rocket-top');
    window.addEventListener('scroll', () => {
      if (!rocketBtn) return;
      if (window.scrollY > 600) rocketBtn.classList.add('visible');
      else rocketBtn.classList.remove('visible');
    });
    rocketBtn?.addEventListener('click', () => {
      rocketBtn.classList.add('launching');
      rocketBtn.querySelector('.rocket-flames')?.classList.add('opacity-100');
      window.scrollTo({ top: 0, behavior: 'smooth' });
      setTimeout(() => {
        rocketBtn.classList.remove('launching', 'visible');
      }, 1000);
    });
  </script>

</Layout>
