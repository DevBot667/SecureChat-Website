---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title="SecureChat — 404">

  <div class="min-h-screen flex flex-col items-center justify-center relative overflow-hidden px-6">

    <!-- Three.js canvas for void particles -->
    <canvas id="void-canvas" class="absolute inset-0 w-full h-full"></canvas>

    <!-- Content -->
    <div class="relative z-10 text-center max-w-lg">

      <!-- Animated glitch 404 -->
      <h1 class="text-[10rem] md:text-[14rem] font-black font-['Space_Grotesk'] leading-none gradient-text glitch select-none" data-text="404">404</h1>

      <!-- Encrypted message animation -->
      <div class="glass-strong rounded-2xl p-6 mb-8 mt-4">
        <div class="font-['JetBrains_Mono'] text-sm text-phantom-light/60 mb-2" data-lang="fr">Message intercepté :</div>
        <div class="font-['JetBrains_Mono'] text-sm text-phantom-light/60 mb-2" data-lang="en">Intercepted message:</div>
        <div id="cipher-text" class="font-['JetBrains_Mono'] text-xs text-text-muted break-all h-12 flex items-center justify-center"></div>
        <div class="mt-3 flex items-center justify-center gap-2">
          <div class="w-2 h-2 rounded-full bg-accent-red animate-pulse"></div>
          <span class="text-xs text-accent-red font-['JetBrains_Mono']" data-lang="fr">DÉCHIFFREMENT IMPOSSIBLE — clé perdue dans le void</span>
          <span class="text-xs text-accent-red font-['JetBrains_Mono']" data-lang="en">DECRYPTION FAILED — key lost in the void</span>
        </div>
      </div>

      <p class="text-xl text-text-secondary mb-2" data-lang="fr">Cette page n'existe pas… ou a été <span class="text-phantom-light">autodétruite</span>.</p>
      <p class="text-xl text-text-secondary mb-2" data-lang="en">This page doesn't exist… or was <span class="text-phantom-light">self-destructed</span>.</p>
      <p class="text-sm text-text-muted mb-8" data-lang="fr">Le message que vous cherchez a peut-être expiré.</p>
      <p class="text-sm text-text-muted mb-8" data-lang="en">The message you're looking for may have expired.</p>

      <a href={base} class="inline-flex items-center gap-3 px-8 py-4 bg-phantom hover:bg-phantom-light text-white font-semibold rounded-2xl transition-all hover:scale-105 glow-phantom-strong">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 12h18M3 12l6-6M3 12l6 6"/></svg>
        <span data-lang="fr">Retour à l'accueil</span><span data-lang="en">Back to home</span>
      </a>
    </div>
  </div>

  <script>
    // Language
    let currentLang = 'fr';
    document.addEventListener('keydown', (e) => {
      if (e.key === 'l') { currentLang = currentLang === 'fr' ? 'en' : 'fr'; document.documentElement.classList.remove('lang-fr','lang-en'); document.documentElement.classList.add(`lang-${currentLang}`); document.documentElement.lang = currentLang; }
    });

    // Cipher text animation — random hex that constantly changes
    const cipherEl = document.getElementById('cipher-text');
    function randomHex(len: number) { const chars = '0123456789abcdef'; let s = ''; for (let i = 0; i < len; i++) { if (i > 0 && i % 4 === 0) s += ' '; s += chars[Math.floor(Math.random() * 16)]; } return s; }
    setInterval(() => { if (cipherEl) cipherEl.textContent = randomHex(64); }, 80);
    if (cipherEl) cipherEl.textContent = randomHex(64);

    // Three.js void particles
    async function initVoid() {
      const THREE = await import('three');
      const canvas = document.getElementById('void-canvas') as HTMLCanvasElement;
      if (!canvas) return;
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 100);
      camera.position.z = 30;

      // Particles spiraling into void
      const count = 400;
      const geo = new THREE.BufferGeometry();
      const pos = new Float32Array(count * 3);
      const vel = new Float32Array(count * 3);
      for (let i = 0; i < count; i++) {
        const angle = Math.random() * Math.PI * 2;
        const radius = 5 + Math.random() * 25;
        pos[i * 3] = Math.cos(angle) * radius;
        pos[i * 3 + 1] = (Math.random() - 0.5) * 30;
        pos[i * 3 + 2] = Math.sin(angle) * radius + (Math.random() - 0.5) * 10;
        vel[i * 3] = 0;
        vel[i * 3 + 1] = 0;
        vel[i * 3 + 2] = 0;
      }
      geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));

      const mat = new THREE.PointsMaterial({ color: 0x9C4DCC, size: 0.15, transparent: true, opacity: 0.6, sizeAttenuation: true });
      const points = new THREE.Points(geo, mat);
      scene.add(points);

      // Central void glow
      const voidGeo = new THREE.SphereGeometry(1.5, 32, 32);
      const voidMat = new THREE.MeshBasicMaterial({ color: 0x7B2D8E, transparent: true, opacity: 0.15 });
      const voidSphere = new THREE.Mesh(voidGeo, voidMat);
      scene.add(voidSphere);

      function animate() {
        requestAnimationFrame(animate);
        const positions = geo.attributes.position.array as Float32Array;
        for (let i = 0; i < count; i++) {
          const ix = i * 3, iy = i * 3 + 1, iz = i * 3 + 2;
          const x = positions[ix], y = positions[iy], z = positions[iz];
          const dist = Math.sqrt(x * x + y * y + z * z);
          // Spiral pull toward center
          const pull = 0.003 + 0.015 / (dist + 1);
          positions[ix] -= x * pull;
          positions[iy] -= y * pull * 0.5;
          positions[iz] -= z * pull;
          // Add rotation
          const angle = 0.002;
          const nx = positions[ix] * Math.cos(angle) - positions[iz] * Math.sin(angle);
          const nz = positions[ix] * Math.sin(angle) + positions[iz] * Math.cos(angle);
          positions[ix] = nx;
          positions[iz] = nz;
          // Respawn if too close to center
          if (dist < 1) {
            const a = Math.random() * Math.PI * 2;
            const r = 15 + Math.random() * 15;
            positions[ix] = Math.cos(a) * r;
            positions[iy] = (Math.random() - 0.5) * 30;
            positions[iz] = Math.sin(a) * r;
          }
        }
        geo.attributes.position.needsUpdate = true;
        voidSphere.scale.setScalar(1 + Math.sin(Date.now() * 0.002) * 0.2);
        (voidMat as THREE.MeshBasicMaterial).opacity = 0.1 + Math.sin(Date.now() * 0.003) * 0.05;
        renderer.render(scene, camera);
      }
      animate();

      window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
      });
    }
    initVoid();
  </script>

</Layout>
