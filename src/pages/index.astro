  <!-- ===== SCRIPTS ===== -->
  <script>
    // ---- Language Switcher ----
    const langToggle = document.getElementById('lang-toggle');
    let currentLang = 'fr';
    langToggle?.addEventListener('click', () => {
      currentLang = currentLang === 'fr' ? 'en' : 'fr';
      document.documentElement.classList.remove('lang-fr', 'lang-en');
      document.documentElement.classList.add(`lang-${currentLang}`);
      document.documentElement.lang = currentLang;
    });

    // ---- Scroll Progress Bar ----
    const scrollBar = document.getElementById('scroll-progress');
    window.addEventListener('scroll', () => {
      if (!scrollBar) return;
      const h = document.documentElement.scrollHeight - window.innerHeight;
      scrollBar.style.width = h > 0 ? `${(window.scrollY / h * 100)}%` : '0%';
    });

    // ---- Typing Effect ----
    function typeWriter(elId: string, phrases: string[]) {
      const el = document.getElementById(elId);
      if (!el) return;
      let pi = 0, ci = 0, del = false;
      function tick() {
        const p = phrases[pi];
        if (del) { el.textContent = p.substring(0, ci - 1); ci--; }
        else { el.textContent = p.substring(0, ci + 1); ci++; }
        let d = del ? 30 : 60;
        if (!del && ci === p.length) { d = 2000; del = true; }
        else if (del && ci === 0) { del = false; pi = (pi + 1) % phrases.length; d = 500; }
        setTimeout(tick, d);
      }
      tick();
    }
    typeWriter('typing-text-fr', ["La messagerie qui ne sait rien de vous.", "Chiffrement de bout en bout.", "Zéro métadonnée. Zéro compromis.", "Private by design."]);
    typeWriter('typing-text-en', ["The messenger that knows nothing about you.", "End-to-end encrypted.", "Zero metadata. Zero compromise.", "Private by design."]);

    // ---- Count Up ----
    function animateCountUp() {
      document.querySelectorAll('[data-count]').forEach(el => {
        const target = parseInt(el.getAttribute('data-count') || '0');
        if (target === 0) { (el as HTMLElement).textContent = '0'; return; }
        let cur = 0; const inc = target / 40;
        const t = setInterval(() => { cur += inc; if (cur >= target) { cur = target; clearInterval(t); } (el as HTMLElement).textContent = Math.floor(cur).toString(); }, 30);
      });
    }

    // ---- Scroll Reveal ----
    const obs = new IntersectionObserver(e => { e.forEach(x => { if (x.isIntersecting) x.target.classList.add('visible'); }); }, { threshold: 0.1 });
    document.querySelectorAll('.section-reveal').forEach(el => obs.observe(el));
    const statsObs = new IntersectionObserver(e => { e.forEach(x => { if (x.isIntersecting) { animateCountUp(); statsObs.disconnect(); } }); }, { threshold: 0.5 });
    const statsEl = document.querySelector('[data-count]')?.closest('div');
    if (statsEl) statsObs.observe(statsEl);

    // ---- Entropy Bits ----
    const entropyC = document.getElementById('entropy-bits');
    if (entropyC) { for (let i = 0; i < 256; i++) { const s = document.createElement('span'); const v = Math.random() > 0.5 ? '1' : '0'; s.textContent = v; s.className = v === '1' ? 'text-phantom-light' : 'text-text-muted/40'; entropyC.appendChild(s); } }

    // ---- Emoji Fingerprint ----
    const emojiPalette = ['😀','😎','🥳','😈','👻','💀','🤖','👽','🐶','🐱','🦊','🐻','🐼','🐸','🦁','🐲','🌸','🌺','🌻','🌹','🍀','🌴','🌊','⭐','🔥','❄️','⚡','🌙','☀️','🌈','💎','🎯','🎵','🎸','🎮','🎲','🏆','🎪','🎭','🎨','🍕','🍔','🍟','🌮','🍣','🍪','🍰','🧁','🚀','✈️','🛸','🏎️','⛵','🎈','🎁','🔮','💜','💙','💚','💛','🧡','❤️','🤍','🖤'];
    const fpEl = document.getElementById('emoji-fingerprint');
    if (fpEl) { for (let i = 0; i < 16; i++) { const s = document.createElement('span'); s.textContent = emojiPalette[Math.floor(Math.random() * 64)]; s.className = 'transition-transform hover:scale-125 cursor-default'; fpEl.appendChild(s); } }

    // ---- Live Encryption Demo (Web Crypto) ----
    let encKeyHex = '', encIvHex = '';
    async function initEncryption() {
      const key = await crypto.subtle.generateKey({ name: 'AES-GCM', length: 256 }, true, ['encrypt']);
      const raw = await crypto.subtle.exportKey('raw', key);
      encKeyHex = Array.from(new Uint8Array(raw)).map(b => b.toString(16).padStart(2, '0')).join('');
      const keyEl = document.getElementById('encrypt-key');
      if (keyEl) keyEl.textContent = encKeyHex;

      const input = document.getElementById('encrypt-input') as HTMLInputElement;
      input?.addEventListener('input', async () => {
        const text = input.value;
        if (!text) { setEncOutput('—', '—'); return; }
        const iv = crypto.getRandomValues(new Uint8Array(12));
        encIvHex = Array.from(iv).map(b => b.toString(16).padStart(2, '0')).join('');
        const ivEl = document.getElementById('encrypt-iv');
        if (ivEl) ivEl.textContent = encIvHex;
        const enc = new TextEncoder();
        const ct = await crypto.subtle.encrypt({ name: 'AES-GCM', iv }, key, enc.encode(text));
        const b64 = btoa(String.fromCharCode(...new Uint8Array(ct)));
        const outEl = document.getElementById('encrypt-output');
        if (outEl) { outEl.textContent = b64; outEl.classList.add('text-phantom-light'); }
      });
    }
    function setEncOutput(iv: string, out: string) {
      const ivEl = document.getElementById('encrypt-iv');
      const outEl = document.getElementById('encrypt-output');
      if (ivEl) ivEl.textContent = iv;
      if (outEl) { outEl.textContent = out; outEl.classList.remove('text-phantom-light'); }
    }
    initEncryption();

    // ---- 3D Tilt Cards ----
    document.querySelectorAll('.tilt-card').forEach(card => {
      const el = card as HTMLElement;
      el.addEventListener('mousemove', (e: MouseEvent) => {
        const r = el.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        el.style.transform = `perspective(800px) rotateY(${x * 15}deg) rotateX(${-y * 15}deg)`;
      });
      el.addEventListener('mouseleave', () => { el.style.transform = 'perspective(800px) rotateY(0deg) rotateX(0deg)'; });
    });

    // ---- Parallax ----
    window.addEventListener('scroll', () => {
      const sy = window.scrollY;
      document.querySelectorAll('.parallax-slow').forEach(el => { (el as HTMLElement).style.transform = `translateY(${sy * 0.05}px)`; });
      document.querySelectorAll('.parallax-fast').forEach(el => { (el as HTMLElement).style.transform = `translateY(${sy * 0.12}px)`; });
    });

    // ---- GitHub Stats (commits count) ----
    async function fetchGHStats() {
      try {
        const resp = await fetch('https://api.github.com/repos/DevBot667/SecureChat');
        if (!resp.ok) return;
        const data = await resp.json();
        const el = document.getElementById('gh-commits');
        if (el && data.size) {
          // GitHub API doesn't directly give commit count easily, use contributors stats
          const cResp = await fetch('https://api.github.com/repos/DevBot667/SecureChat/contributors');
          if (cResp.ok) {
            const contributors = await cResp.json();
            const total = contributors.reduce((s: number, c: any) => s + (c.contributions || 0), 0);
            if (total > 0) { el.setAttribute('data-count', total.toString()); el.textContent = total.toString(); }
          }
        }
      } catch { /* silent */ }
    }
    fetchGHStats();

    // ---- Easter Egg (Konami Code) ----
    const konamiCode = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
    let konamiIdx = 0;
    document.addEventListener('keydown', (e) => {
      if (e.key === konamiCode[konamiIdx]) {
        konamiIdx++;
        if (konamiIdx === konamiCode.length) {
          konamiIdx = 0;
          document.body.classList.add('easter-unlocked');
          const msg = document.createElement('div');
          msg.className = 'fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-[9999] glass-strong rounded-3xl p-12 text-center';
          msg.innerHTML = `<div class="text-6xl mb-4">🔓</div><div class="text-2xl font-bold font-['Space_Grotesk'] gradient-text mb-2">Easter Egg Unlocked!</div><div class="text-text-secondary">You found the secret. You're a true cypherpunk. 🫡</div>`;
          document.body.appendChild(msg);
          setTimeout(() => { msg.remove(); document.body.classList.remove('easter-unlocked'); }, 4000);
        }
      } else { konamiIdx = 0; }
    });

    // ---- Three.js Hero (Particles + Connected Lines + Wireframe Lock) ----
    async function initHeroCanvas() {
      const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
      if (!canvas) return;
      const THREE = await import('three');
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      // Particles
      const pc = 600;
      const pos = new Float32Array(pc * 3);
      const cols = new Float32Array(pc * 3);
      const velocities: number[] = [];
      for (let i = 0; i < pc; i++) {
        pos[i*3] = (Math.random()-0.5)*50; pos[i*3+1] = (Math.random()-0.5)*50; pos[i*3+2] = (Math.random()-0.5)*50;
        cols[i*3] = 0.48+Math.random()*0.15; cols[i*3+1] = 0.18+Math.random()*0.1; cols[i*3+2] = 0.55+Math.random()*0.25;
        velocities.push((Math.random()-0.5)*0.02, (Math.random()-0.5)*0.02, (Math.random()-0.5)*0.02);
      }
      const pGeo = new THREE.BufferGeometry();
      pGeo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
      pGeo.setAttribute('color', new THREE.BufferAttribute(cols, 3));
      const pMat = new THREE.PointsMaterial({ size: 0.1, vertexColors: true, transparent: true, opacity: 0.7, blending: THREE.AdditiveBlending });
      const particles = new THREE.Points(pGeo, pMat);
      scene.add(particles);

      // Connection lines
      const lineGeo = new THREE.BufferGeometry();
      const linePositions = new Float32Array(pc * pc * 0.01 * 6); // rough max
      lineGeo.setAttribute('position', new THREE.BufferAttribute(linePositions, 3));
      const lineMat = new THREE.LineBasicMaterial({ color: 0x7B2D8E, transparent: true, opacity: 0.15, blending: THREE.AdditiveBlending });
      const lines = new THREE.LineSegments(lineGeo, lineMat);
      scene.add(lines);

      // Wireframe lock
      const lockGroup = new THREE.Group();
      const bodyGeo = new THREE.BoxGeometry(2.5, 2, 1.5, 4, 4, 4);
      const bodyMat = new THREE.MeshBasicMaterial({ color: 0x7B2D8E, wireframe: true, transparent: true, opacity: 0.3 });
      const body = new THREE.Mesh(bodyGeo, bodyMat); body.position.y = -0.5; lockGroup.add(body);
      const curve = new THREE.CatmullRomCurve3([new THREE.Vector3(-0.8,0.5,0), new THREE.Vector3(-0.8,1.8,0), new THREE.Vector3(0,2.4,0), new THREE.Vector3(0.8,1.8,0), new THREE.Vector3(0.8,0.5,0)]);
      const tubeGeo = new THREE.TubeGeometry(curve, 20, 0.15, 8, false);
      const tubeMat = new THREE.MeshBasicMaterial({ color: 0x9C4DCC, wireframe: true, transparent: true, opacity: 0.4 });
      lockGroup.add(new THREE.Mesh(tubeGeo, tubeMat));
      lockGroup.position.set(3, 0, -5); lockGroup.scale.set(1.5, 1.5, 1.5);
      scene.add(lockGroup);
      camera.position.z = 15;

      let mX = 0, mY = 0;
      document.addEventListener('mousemove', e => { mX = (e.clientX / window.innerWidth - 0.5) * 2; mY = (e.clientY / window.innerHeight - 0.5) * 2; });

      function animate() {
        requestAnimationFrame(animate);

        // Move particles
        const pArr = pGeo.attributes.position.array as Float32Array;
        for (let i = 0; i < pc; i++) {
          pArr[i*3] += velocities[i*3]; pArr[i*3+1] += velocities[i*3+1]; pArr[i*3+2] += velocities[i*3+2];
          if (Math.abs(pArr[i*3]) > 25) velocities[i*3] *= -1;
          if (Math.abs(pArr[i*3+1]) > 25) velocities[i*3+1] *= -1;
          if (Math.abs(pArr[i*3+2]) > 25) velocities[i*3+2] *= -1;
        }
        pGeo.attributes.position.needsUpdate = true;

        // Update connection lines (connect nearby particles)
        const lArr = lineGeo.attributes.position.array as Float32Array;
        let li = 0;
        const maxDist = 6;
        for (let i = 0; i < pc && li < lArr.length - 6; i += 3) {
          for (let j = i + 3; j < pc && li < lArr.length - 6; j += 3) {
            const dx = pArr[i*3] - pArr[j*3], dy = pArr[i*3+1] - pArr[j*3+1], dz = pArr[i*3+2] - pArr[j*3+2];
            if (dx*dx + dy*dy + dz*dz < maxDist*maxDist) {
              lArr[li++] = pArr[i*3]; lArr[li++] = pArr[i*3+1]; lArr[li++] = pArr[i*3+2];
              lArr[li++] = pArr[j*3]; lArr[li++] = pArr[j*3+1]; lArr[li++] = pArr[j*3+2];
            }
          }
        }
        for (let k = li; k < lArr.length; k++) lArr[k] = 0;
        lineGeo.attributes.position.needsUpdate = true;

        particles.rotation.y += 0.0003;
        lockGroup.rotation.y += 0.005; lockGroup.rotation.x = mY * 0.1; lockGroup.rotation.z = mX * 0.05;
        camera.position.x += (mX * 0.5 - camera.position.x) * 0.02;
        camera.position.y += (-mY * 0.5 - camera.position.y) * 0.02;
        camera.lookAt(scene.position);
        renderer.render(scene, camera);
      }
      animate();
      window.addEventListener('resize', () => { camera.aspect = window.innerWidth / window.innerHeight; camera.updateProjectionMatrix(); renderer.setSize(window.innerWidth, window.innerHeight); });
    }
    initHeroCanvas();

    // ---- GSAP Animations ----
    async function initGSAP() {
      const { gsap } = await import('gsap');
      const { ScrollTrigger } = await import('gsap/ScrollTrigger');
      gsap.registerPlugin(ScrollTrigger);
      gsap.utils.toArray('.tilt-card').forEach((card, i) => { gsap.from(card as Element, { scrollTrigger: { trigger: card as Element, start: 'top 85%' }, y: 60, opacity: 0, duration: 0.6, delay: i * 0.08 }); });
      gsap.utils.toArray('.timeline-item').forEach((item, i) => { gsap.from(item as Element, { scrollTrigger: { trigger: item as Element, start: 'top 80%' }, x: -40, opacity: 0, duration: 0.6, delay: i * 0.15 }); });
      gsap.utils.toArray('tbody tr').forEach((row, i) => { gsap.from(row as Element, { scrollTrigger: { trigger: row as Element, start: 'top 90%' }, x: -20, opacity: 0, duration: 0.4, delay: i * 0.05 }); });
      gsap.utils.toArray('.arch-node').forEach((node, i) => { gsap.from(node as Element, { scrollTrigger: { trigger: node as Element, start: 'top 85%' }, scale: 0.5, opacity: 0, duration: 0.5, delay: i * 0.15 }); });
    }
    initGSAP();

    // ---- Smooth scroll ----
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', function(this: HTMLAnchorElement, e: Event) { e.preventDefault(); document.querySelector(this.getAttribute('href')!)?.scrollIntoView({ behavior: 'smooth' }); });
    });
  </script>

</Layout>
