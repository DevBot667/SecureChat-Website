  <!-- ===== VS 7: SPQR (Triple Ratchet) ===== -->
  <section id="vs-spqr" class="py-24 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-surface via-surface-light/20 to-surface pointer-events-none"></div>
    <div class="relative max-w-6xl mx-auto px-6">
      <div class="text-center mb-12 section-reveal">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass text-sm text-phantom-light mb-4">
