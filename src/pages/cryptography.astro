  <script>
    // Mobile Menu Toggle
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    mobileMenuBtn?.addEventListener('click', () => {
      mobileMenuBtn.closest('nav')?.classList.toggle('menu-open');
      mobileMenu?.classList.toggle('hidden');
      mobileMenu?.classList.toggle('open');
    });

    // Language
    const langToggle = document.getElementById('lang-toggle');
    let currentLang = 'fr';
    langToggle?.addEventListener('click', () => {
      currentLang = currentLang === 'fr' ? 'en' : 'fr';
      document.documentElement.classList.remove('lang-fr','lang-en');
      document.documentElement.classList.add(`lang-${currentLang}`);
      document.documentElement.lang = currentLang;
    });

    // Scroll progress
    const sp = document.getElementById('scroll-progress');
    window.addEventListener('scroll', () => { if (!sp) return; const h = document.documentElement.scrollHeight - window.innerHeight; sp.style.width = h > 0 ? `${(window.scrollY/h*100)}%` : '0%'; });

    // GSAP scroll animations (enhanced)
    async function initGSAP() {
      const { gsap } = await import('gsap');
      const { ScrollTrigger } = await import('gsap/ScrollTrigger');
      gsap.registerPlugin(ScrollTrigger);

      // Stagger stack cards
      gsap.utils.toArray('.crypto-stack-card').forEach((card, i) => {
        gsap.fromTo(card as Element, { y: 40, opacity: 0 }, { scrollTrigger: { trigger: card as Element, start: 'top 85%' }, y: 0, opacity: 1, duration: 0.5, delay: i * 0.06 });
      });

      // Table rows — slide from left with stagger
      gsap.utils.toArray('tbody tr').forEach((row, i) => {
        gsap.fromTo(row as Element, { x: -30, opacity: 0 }, { scrollTrigger: { trigger: row as Element, start: 'top 92%' }, x: 0, opacity: 1, duration: 0.5, delay: i * 0.04, ease: 'power2.out' });
      });

      // Section reveals — smooth power3
      gsap.utils.toArray('.section-reveal').forEach(el => {
        gsap.fromTo(el as Element, { y: 60, opacity: 0 }, { scrollTrigger: { trigger: el as Element, start: 'top 82%' }, y: 0, opacity: 1, duration: 0.8, ease: 'power3.out' });
      });

      // Section headings — skew + slide reveal
      gsap.utils.toArray('section[id^="vs-"] h2').forEach(el => {
        gsap.fromTo(el as Element, { x: -50, opacity: 0, skewX: -5 }, { scrollTrigger: { trigger: el as Element, start: 'top 88%' }, x: 0, opacity: 1, skewX: 0, duration: 0.7, ease: 'power3.out' });
      });

      // Comparison marks — bouncy pop
      gsap.utils.toArray('.compare-check, .compare-cross, .compare-partial').forEach((el, i) => {
        gsap.fromTo(el as Element, { scale: 0 }, { scrollTrigger: { trigger: el as Element, start: 'top 93%' }, scale: 1, duration: 0.35, delay: (i % 6) * 0.04, ease: 'back.out(3)' });
      });

      // Code blocks — slide from right
      gsap.utils.toArray('pre').forEach(el => {
        gsap.fromTo(el as Element, { x: 30, opacity: 0 }, { scrollTrigger: { trigger: el as Element, start: 'top 88%' }, x: 0, opacity: 1, duration: 0.6, ease: 'power2.out' });
      });

      // Glass info boxes (not already section-reveal) — scale pop
      gsap.utils.toArray('.glass:not(.section-reveal)').forEach(el => {
        gsap.fromTo(el as Element, { scale: 0.92, opacity: 0 }, { scrollTrigger: { trigger: el as Element, start: 'top 85%' }, scale: 1, opacity: 1, duration: 0.6, ease: 'back.out(1.5)' });
      });
    }
    initGSAP();

    // Section reveal observer fallback
    const obs = new IntersectionObserver(e => { e.forEach(x => { if (x.isIntersecting) x.target.classList.add('visible'); }); }, { threshold: 0.1 });
    document.querySelectorAll('.section-reveal').forEach(el => obs.observe(el));

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', function(this: HTMLAnchorElement, e: Event) { e.preventDefault(); document.querySelector(this.getAttribute('href')!)?.scrollIntoView({ behavior: 'smooth' }); });
    });

    // ---- Rocket Section Navigator (with DRAG-TO-SCROLL) ----
    const rocketNav = document.getElementById('rocket-nav');
    const rocketShip = document.getElementById('rocket-ship');
    const rocketTrackFill = document.getElementById('rocket-track-fill');
    const stations = document.querySelectorAll('.rocket-station');
    const sectionIds = Array.from(stations).map(s => s.getAttribute('data-target')!);
    const sectionEls = sectionIds.map(id => document.getElementById(id)).filter(Boolean) as HTMLElement[];
    let isDragging = false;

    // Show/hide + track position
    function updateRocketNav() {
      if (!rocketNav || !rocketShip || sectionEls.length === 0) return;

      const scrollY = window.scrollY;
      const firstSection = sectionEls[0];
      const showAfter = firstSection.offsetTop - window.innerHeight * 0.5;

      if (scrollY > showAfter) {
        rocketNav.classList.add('visible');
      } else {
        rocketNav.classList.remove('visible');
        return;
      }

      // Find current section
      let activeIdx = 0;
      for (let i = sectionEls.length - 1; i >= 0; i--) {
        if (scrollY >= sectionEls[i].offsetTop - window.innerHeight * 0.4) {
          activeIdx = i;
          break;
        }
      }

      // Move rocket to active station (skip if dragging — user controls it)
      if (!isDragging) {
        const stationArr = Array.from(stations);
        const targetStation = stationArr[activeIdx];
        if (targetStation) {
          const stationsContainer = document.getElementById('rocket-stations');
          if (stationsContainer) {
            const containerRect = stationsContainer.getBoundingClientRect();
            const stationRect = targetStation.getBoundingClientRect();
            const offset = stationRect.top - containerRect.top + stationRect.height / 2 - 24;
            rocketShip.style.top = `${offset}px`;
          }
        }
      }

      // Update active dots
      stations.forEach((s, i) => {
        const dot = s.querySelector('.w-3');
        if (i === activeIdx) dot?.classList.add('active');
        else dot?.classList.remove('active');
      });

      // Update track fill
      if (rocketTrackFill) {
        const ratio = sectionEls.length > 1 ? activeIdx / (sectionEls.length - 1) : 0;
        rocketTrackFill.style.height = `${ratio * 100}%`;
      }
    }

    // Click handlers for stations
    stations.forEach(station => {
      station.addEventListener('click', () => {
        if (isDragging) return;
        const targetId = station.getAttribute('data-target');
        const target = document.getElementById(targetId!);
        if (!target || !rocketShip) return;

        rocketShip.classList.add('flying');
        setTimeout(() => rocketShip.classList.remove('flying'), 500);
        target.scrollIntoView({ behavior: 'smooth' });
      });
    });

    // ==== DRAG-TO-SCROLL (like a real scrollbar!) ====
    if (rocketShip && rocketNav) {
      function startDrag(clientY: number) {
        isDragging = true;
        rocketShip!.classList.add('dragging');
        rocketNav!.classList.add('nav-dragging');
        document.body.style.userSelect = 'none';
        (document.body.style as any).webkitUserSelect = 'none';
        onDrag(clientY);
      }

      function onDrag(clientY: number) {
        if (!isDragging) return;
        const stationsContainer = document.getElementById('rocket-stations');
        if (!stationsContainer || sectionEls.length < 2) return;

        const containerRect = stationsContainer.getBoundingClientRect();
        const relativeY = clientY - containerRect.top;
        const ratio = Math.max(0, Math.min(1, relativeY / containerRect.height));

        // Map ratio → page scroll position (first section to last section)
        const firstTop = sectionEls[0].offsetTop - 100;
        const lastEl = sectionEls[sectionEls.length - 1];
        const lastBottom = lastEl.offsetTop + lastEl.offsetHeight;
        const scrollRange = lastBottom - firstTop - window.innerHeight;
        window.scrollTo({ top: firstTop + ratio * scrollRange, behavior: 'auto' });

        // Move rocket directly (instant, no transition lag)
        const offset = ratio * (containerRect.height - 48);
        rocketShip!.style.top = `${offset}px`;
        rocketShip!.style.transition = 'none';

        // Track fill
        if (rocketTrackFill) {
          rocketTrackFill.style.height = `${ratio * 100}%`;
        }
      }

      function endDrag() {
        if (!isDragging) return;
        isDragging = false;
        rocketShip!.classList.remove('dragging');
        rocketNav!.classList.remove('nav-dragging');
        rocketShip!.style.transition = '';
        document.body.style.userSelect = '';
        (document.body.style as any).webkitUserSelect = '';

        // Boost animation on release
        rocketShip!.classList.add('flying');
        setTimeout(() => rocketShip!.classList.remove('flying'), 500);
      }

      // Mouse events
      rocketShip.addEventListener('mousedown', (e: MouseEvent) => { e.preventDefault(); startDrag(e.clientY); });
      document.addEventListener('mousemove', (e: MouseEvent) => { if (isDragging) { e.preventDefault(); onDrag(e.clientY); } });
      document.addEventListener('mouseup', endDrag);

      // Touch events
      rocketShip.addEventListener('touchstart', (e: TouchEvent) => { e.preventDefault(); startDrag(e.touches[0].clientY); }, { passive: false });
      document.addEventListener('touchmove', (e: TouchEvent) => { if (isDragging) { e.preventDefault(); onDrag(e.touches[0].clientY); } }, { passive: false });
      document.addEventListener('touchend', endDrag);
    }

    window.addEventListener('scroll', updateRocketNav, { passive: true });
    window.addEventListener('resize', updateRocketNav);
    setTimeout(updateRocketNav, 500);

    // Three.js particle background for hero
    async function initCryptoCanvas() {
      const canvas = document.getElementById('crypto-canvas') as HTMLCanvasElement;
      if (!canvas) return;
      const THREE = await import('three');
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      // Floating geometric shapes (crypto-themed)
      const group = new THREE.Group();

      // Icosahedron (represents complexity)
      const icoGeo = new THREE.IcosahedronGeometry(3, 1);
      const icoMat = new THREE.MeshBasicMaterial({ color: 0x9C4DCC, wireframe: true, transparent: true, opacity: 0.15 });
      const ico = new THREE.Mesh(icoGeo, icoMat);
      ico.position.set(-8, 2, -10);
      group.add(ico);

      // Torus knot (represents key exchange)
      const tkGeo = new THREE.TorusKnotGeometry(2, 0.5, 64, 8, 2, 3);
      const tkMat = new THREE.MeshBasicMaterial({ color: 0x7B2D8E, wireframe: true, transparent: true, opacity: 0.12 });
      const tk = new THREE.Mesh(tkGeo, tkMat);
      tk.position.set(10, -3, -15);
      group.add(tk);

      // Octahedron (represents encryption)
      const octGeo = new THREE.OctahedronGeometry(2, 0);
      const octMat = new THREE.MeshBasicMaterial({ color: 0xB44FE0, wireframe: true, transparent: true, opacity: 0.1 });
      const oct = new THREE.Mesh(octGeo, octMat);
      oct.position.set(0, 5, -8);
      group.add(oct);

      // Particles
      const pc = 300;
      const pGeo = new THREE.BufferGeometry();
      const pPos = new Float32Array(pc * 3);
      for (let i = 0; i < pc; i++) {
        pPos[i*3] = (Math.random()-0.5) * 40;
        pPos[i*3+1] = (Math.random()-0.5) * 30;
        pPos[i*3+2] = (Math.random()-0.5) * 30 - 10;
      }
      pGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
      const pMat = new THREE.PointsMaterial({ color: 0x9C4DCC, size: 0.08, transparent: true, opacity: 0.4 });
      group.add(new THREE.Points(pGeo, pMat));

      scene.add(group);
      camera.position.z = 15;

      let mX = 0, mY = 0;
      document.addEventListener('mousemove', e => {
        mX = (e.clientX / window.innerWidth - 0.5) * 2;
        mY = (e.clientY / window.innerHeight - 0.5) * 2;
      });

      function animate() {
        requestAnimationFrame(animate);
        ico.rotation.x += 0.003; ico.rotation.y += 0.005;
        tk.rotation.x += 0.002; tk.rotation.z += 0.004;
        oct.rotation.y += 0.004; oct.rotation.z += 0.002;
        camera.position.x += (mX * 0.3 - camera.position.x) * 0.02;
        camera.position.y += (-mY * 0.3 - camera.position.y) * 0.02;
        camera.lookAt(scene.position);
        renderer.render(scene, camera);
      }
      animate();

      window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
      });
    }
    initCryptoCanvas();
  </script>

</Layout>
