  <style>
    /* === FLAME ANIMATIONS === */
    @keyframes rflame1 { 0%,100% { height: 10px; opacity: 0.8; } 50% { height: 18px; opacity: 1; } }
    @keyframes rflame2 { 0%,100% { height: 16px; opacity: 0.9; } 50% { height: 24px; opacity: 1; } }
    @keyframes rflame3 { 0%,100% { height: 8px; opacity: 0.7; } 50% { height: 16px; opacity: 1; } }
    .animate-rflame1 { animation: rflame1 0.3s ease-in-out infinite; }
    .animate-rflame2 { animation: rflame2 0.25s ease-in-out infinite; }
    .animate-rflame3 { animation: rflame3 0.35s ease-in-out infinite; }

    /* === ROCKET VISIBILITY === */
    #rocket-nav.visible { opacity: 1; pointer-events: auto; }

    /* === GLOW PULSE (idle) === */
    @keyframes glowPulse {
      0%, 100% { filter: drop-shadow(0 0 8px rgba(156, 77, 204, 0.4)); }
      50% { filter: drop-shadow(0 0 18px rgba(156, 77, 204, 0.7)); }
    }
    #rocket-ship { animation: glowPulse 3s ease-in-out infinite; cursor: grab; }

    /* === GLOW RING === */
    .rocket-glow-ring {
      background: radial-gradient(circle, rgba(156,77,204,0.12) 0%, transparent 70%);
      animation: ringPulse 2s ease-in-out infinite;
    }
    @keyframes ringPulse {
      0%, 100% { transform: scale(1); opacity: 0.4; }
      50% { transform: scale(1.4); opacity: 0.7; }
    }

    /* === FLYING STATE (click station) === */
    #rocket-ship.flying { transition-duration: 400ms !important; animation: none !important; }
    #rocket-ship.flying .rocket-svg { animation: rocketShake 0.5s ease-out; }
    @keyframes rocketShake {
      0% { transform: rotate(0deg); }
      15% { transform: rotate(-6deg) scale(1.15); }
      30% { transform: rotate(6deg) scale(1.2); }
      50% { transform: rotate(-3deg) scale(1.1); }
      70% { transform: rotate(2deg); }
      100% { transform: rotate(0deg) scale(1); }
    }
    #rocket-ship.flying #rocket-exhaust { height: 3rem; opacity: 0.7; }
    #rocket-ship.flying #rocket-nav-flames div { height: 1.5rem !important; }

    /* === DRAGGING STATE (grab & scroll) === */
    #rocket-ship.dragging {
      cursor: grabbing !important;
      animation: none !important;
      filter: drop-shadow(0 0 24px rgba(156, 77, 204, 0.9)) !important;
      transition: none !important;
    }
    #rocket-ship.dragging .rocket-svg { transform: scale(1.25); transition: transform 0.15s; }
    #rocket-ship.dragging #rocket-nav-flames div { height: 2rem !important; }
    #rocket-ship.dragging #rocket-exhaust { height: 5rem; opacity: 0.8; filter: blur(8px); }
    #rocket-ship.dragging .rocket-glow-ring { animation: none; transform: scale(1.6); opacity: 1; }

    /* Show ALL labels while dragging */
    #rocket-nav.nav-dragging .station-label {
      opacity: 1 !important;
      transform: translateX(0) !important;
    }
    #rocket-nav.nav-dragging { cursor: grabbing; }

    /* Drag hint on hover */
    #rocket-ship:hover #rocket-drag-hint { opacity: 1; }
    #rocket-ship.dragging #rocket-drag-hint { opacity: 0 !important; }

    /* === ACTIVE STATION DOT === */
    .rocket-station .w-3 { position: relative; }
    .rocket-station .w-3.active {
      border-color: #B44FE0 !important;
      background: rgba(156, 77, 204, 0.5) !important;
      box-shadow: 0 0 12px rgba(156, 77, 204, 0.6);
      transform: scale(1.4);
    }
    /* Ping ring on active dot */
    .rocket-station .w-3.active::after {
      content: '';
      position: absolute; inset: -4px; border-radius: 50%;
      border: 1.5px solid rgba(180, 79, 224, 0.4);
      animation: stationPing 1.5s ease-out infinite;
    }
    .rocket-station[data-target="vs-quantum"] .w-3.active::after {
      border-color: rgba(239, 68, 68, 0.4);
    }
    @keyframes stationPing {
      0% { transform: scale(1); opacity: 1; }
      100% { transform: scale(2.2); opacity: 0; }
    }

    /* === SPARK PARTICLES (drag only) === */
    .rocket-sparks .spark {
      position: absolute; width: 3px; height: 3px; border-radius: 50%;
      background: #FFD700; opacity: 0;
    }
    #rocket-ship.dragging .rocket-sparks .spark { animation: sparkFly 0.6s ease-out infinite; }
    #rocket-ship.dragging .rocket-sparks .spark:nth-child(1) { animation-delay: 0s; left: -6px; }
    #rocket-ship.dragging .rocket-sparks .spark:nth-child(2) { animation-delay: 0.1s; left: -2px; }
    #rocket-ship.dragging .rocket-sparks .spark:nth-child(3) { animation-delay: 0.2s; left: 2px; }
    #rocket-ship.dragging .rocket-sparks .spark:nth-child(4) { animation-delay: 0.15s; left: 6px; }
    #rocket-ship.dragging .rocket-sparks .spark:nth-child(5) { animation-delay: 0.08s; left: -4px; }
    #rocket-ship.dragging .rocket-sparks .spark:nth-child(6) { animation-delay: 0.28s; left: 4px; }
    @keyframes sparkFly {
      0% { transform: translateY(0); opacity: 1; }
      50% { opacity: 0.8; }
      100% { transform: translateY(22px) translateX(var(--sx, 3px)); opacity: 0; }
    }

    /* === TRACK PROGRESS === */
    #rocket-track-fill { box-shadow: 0 0 6px rgba(156, 77, 204, 0.4); }
  </style>

