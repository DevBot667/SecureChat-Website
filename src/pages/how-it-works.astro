  <script>
    // Mobile Menu Toggle
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    mobileMenuBtn?.addEventListener('click', () => {
      mobileMenuBtn.closest('nav')?.classList.toggle('menu-open');
      mobileMenu?.classList.toggle('hidden');
      mobileMenu?.classList.toggle('open');
    });

    // Language
    const langToggle = document.getElementById('lang-toggle');
    let currentLang = 'fr';
    langToggle?.addEventListener('click', () => { currentLang = currentLang === 'fr' ? 'en' : 'fr'; document.documentElement.classList.remove('lang-fr','lang-en'); document.documentElement.classList.add(`lang-${currentLang}`); document.documentElement.lang = currentLang; });
    // Scroll progress
    const sp = document.getElementById('scroll-progress');
    window.addEventListener('scroll', () => { if (!sp) return; const h = document.documentElement.scrollHeight - window.innerHeight; sp.style.width = h > 0 ? `${(window.scrollY/h*100)}%` : '0%'; });
    // Reveal
    const obs = new IntersectionObserver(e => { e.forEach(x => { if (x.isIntersecting) x.target.classList.add('visible'); }); }, { threshold: 0.1 });
    document.querySelectorAll('.section-reveal').forEach(el => obs.observe(el));
    // GSAP
    async function initGSAP() {
      const { gsap } = await import('gsap');
      const { ScrollTrigger } = await import('gsap/ScrollTrigger');
      gsap.registerPlugin(ScrollTrigger);
      gsap.utils.toArray('.ratchet-step').forEach((s, i) => { gsap.from(s as Element, { scrollTrigger: { trigger: s as Element, start: 'top 85%' }, x: i % 2 === 0 ? -30 : 30, opacity: 0, duration: 0.5, delay: i * 0.1 }); });
    }
    initGSAP();

    // ---- Rocket Back to Top ----
    const rocketBtn = document.getElementById('rocket-top');
    window.addEventListener('scroll', () => {
      if (!rocketBtn) return;
      if (window.scrollY > 600) rocketBtn.classList.add('visible');
      else rocketBtn.classList.remove('visible');
    });
    rocketBtn?.addEventListener('click', () => {
      rocketBtn.classList.add('launching');
      rocketBtn.querySelector('.rocket-flames')?.classList.add('opacity-100');
      window.scrollTo({ top: 0, behavior: 'smooth' });
      setTimeout(() => {
        rocketBtn.classList.remove('launching', 'visible');
      }, 1000);
    });
  </script>

